# Copy to .env and fill in values
OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter (optional — enables cloud model routing via https://openrouter.ai)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq (optional — fast OpenAI-compatible cloud inference via https://groq.com)
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=
